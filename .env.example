# === ASHA Sahayak — Environment Configuration ===
# Copy this to .env and fill in your values.

# --- Sarvam AI (India-built models) ---
SARVAM_API_KEY=your_sarvam_api_key_here

# --- Provider Selection ---
# Options: sarvam | mock
REASONING_PROVIDER=sarvam
TRANSLATION_PROVIDER=sarvam
SPEECH_PROVIDER=sarvam

# Options: pytesseract | sarvam | mock
VISION_PROVIDER=sarvam

# Options: local | mock
EMBEDDING_PROVIDER=local

# --- App Mode ---
# Set to false for production; true seeds sample data on startup
DEMO_MODE=false

# --- Databricks (only needed when deployed to Databricks) ---
# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# DATABRICKS_TOKEN=your_databricks_pat
# WAREHOUSE_ID=your_sql_warehouse_id
